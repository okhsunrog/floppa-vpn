# Maintainer: Floppa VPN Team <maintainers@floppa.okhsunrog.dev>
#
# Builds from the local working tree. Usage:
#   cd scripts/arch
#   makepkg -p PKGBUILD-local -si

pkgname=floppa-vpn-local
pkgver=0.3.3
pkgrel=1
pkgdesc='WireGuard VPN desktop client built with Tauri (local build)'
arch=('x86_64')
url='https://github.com/okhsunrog/floppa-vpn'
license=('GPL-3.0-or-later')
install='floppa-vpn.install'
options=(!lto)
provides=('floppa-vpn')
conflicts=('floppa-vpn')

depends=(
  'cairo'
  'desktop-file-utils'
  'gdk-pixbuf2'
  'glib2'
  'gtk3'
  'hicolor-icon-theme'
  'libsoup3'
  'pango'
  'webkit2gtk-4.1'
  'libappindicator-gtk3'
  'libcap'
)

makedepends=(
  'bun'
  'cargo'
  'nodejs'
  'rust'
  'openssl'
  'appmenu-gtk-module'
  'librsvg'
)

# Point to the repo root (two levels up from scripts/arch/)
_repodir="${startdir}/../.."

pkgver() {
  cd "${_repodir}"
  grep -oP '^\s*version:\s*"\K[^"]+' floppa-client/src-tauri/tauri.conf.json5
}

build() {
  cd "${_repodir}/floppa-client"

  bun install --frozen-lockfile
  bun tauri build --bundles deb --ci
}

package() {
  cd "${_repodir}/floppa-client/src-tauri/target/release/bundle/deb"

  local deb_dir
  deb_dir=$(find . -maxdepth 1 -type d -name "Floppa VPN_*" | head -n 1)
  if [[ -z "${deb_dir}" ]]; then
    echo "Failed to find extracted deb bundle directory" >&2
    return 1
  fi

  cp -a "${deb_dir}/data/." "${pkgdir}/"
}
