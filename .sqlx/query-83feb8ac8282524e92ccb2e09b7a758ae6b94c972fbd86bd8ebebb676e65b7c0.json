{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            p.name as plan_name,\n            p.display_name as plan_display_name,\n            s.source,\n            s.starts_at,\n            s.expires_at,\n            p.default_speed_limit_mbps as speed_limit_mbps,\n            p.max_peers\n        FROM subscriptions s\n        JOIN plans p ON s.plan_id = p.id\n        WHERE s.user_id = $1 AND (s.expires_at IS NULL OR s.expires_at > NOW())\n        LIMIT 1\n        ",
