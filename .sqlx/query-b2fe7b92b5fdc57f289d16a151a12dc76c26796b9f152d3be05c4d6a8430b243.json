  "query": "\n        SELECT id, protocol, assigned_ip, sync_status, tx_bytes, rx_bytes, traffic_used_bytes, last_handshake, created_at, device_name, device_id\n        FROM peers\n        WHERE user_id = $1 AND sync_status != 'removed'\n        ORDER BY created_at DESC\n        ",
